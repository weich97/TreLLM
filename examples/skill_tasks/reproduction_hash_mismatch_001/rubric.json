    {
      "id": "environment_fields",
      "description": "Reports commit/tag, Python version, platform, or command",
      "points": 1,
      "any_terms": ["commit", "tag", "python", "platform", "command"]
    },
    {
      "id": "artifact_paths",
      "description": "Mentions artifact paths or SHA-256 hashes",
      "points": 1,
      "any_terms": ["artifact", "sha256", "trajectory.json", "dashboard.html"]
    },
    {
      "id": "data_flags",
      "description": "Checks live API, downloaded market data, or private fills flags",
      "points": 1,
      "any_terms": ["live api", "downloaded market data", "private fills", "data-source"]
    },
    {
      "id": "next_action",
      "description": "Rejects or holds the row until rerun or triage explains the mismatch",
