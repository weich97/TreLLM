{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/weich97/TreLLM/schemas/live_readiness_preflight.schema.json",
  "title": "TreLLM Live Readiness Preflight Bundle",
  "type": "object",
  "required": [
    "schema",
    "capability_manifest",
    "handoff_artifact",
    "approval_artifact",
    "response_artifact",
    "operator_runbook_artifact",
    "approval_checked_at",
    "safety_note"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "trellm_live_readiness_preflight_v0.1" },
    "capability_manifest": { "$ref": "#/$defs/portable_relative_path" },
    "handoff_artifact": { "$ref": "#/$defs/portable_relative_path" },
    "approval_artifact": { "$ref": "#/$defs/portable_relative_path" },
    "response_artifact": { "$ref": "#/$defs/portable_relative_path" },
    "operator_runbook_artifact": { "$ref": "#/$defs/portable_relative_path" },
    "approval_checked_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$|[+-][0-9]{2}:[0-9]{2}$"
    },
    "safety_note": { "type": "string", "pattern": "\\S" }
  },
  "$defs": {
    "portable_relative_path": {
      "type": "string",
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\\\\\s]+$"
    }
  }
}
