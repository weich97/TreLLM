{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/weich97/TreLLM/schemas/reproduction_report.schema.json",
  "title": "TreLLM External Reproduction Report",
  "type": "object",
  "required": [
    "schema",
    "created_at",
    "repository",
    "commit_or_tag",
    "python",
    "commands",
    "artifacts",
    "trajectory_hash",
    "live_api_used",
    "market_data_used",
    "private_fills_used"
  ],
  "properties": {
    "schema": { "const": "tradearena_external_reproduction_pack_v1" },
    "created_at": { "type": "string" },
    "repository": { "type": "string" },
    "commit_or_tag": { "type": "string", "minLength": 1 },
    "git_status_short": { "type": "string" },
    "python": {
      "type": "object",
      "required": ["version", "implementation", "executable", "platform"],
      "properties": {
        "version": { "type": "string" },
        "implementation": { "type": "string" },
        "executable": { "type": "string" },
        "platform": { "type": "string" }
      }
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "argv"],
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "argv": { "type": "array", "items": { "type": "string" } },
          "returncode": { "type": ["integer", "null"] }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "exists"],
        "properties": {
          "path": { "type": "string" },
          "exists": { "type": "boolean" },
          "bytes": { "type": "integer", "minimum": 0 },
          "sha256": { "type": "string" }
        }
      }
    },
    "trajectory_hash": { "type": "object" },
    "live_api_used": { "type": "boolean" },
    "market_data_used": { "type": "string" },
    "private_fills_used": { "type": "boolean" },
    "notes": { "type": "string" }
  }
}
